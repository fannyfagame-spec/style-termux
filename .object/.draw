#!/usr/bin/bash
# 🎨 Warna
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
MAGENTA='\033[1;35m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
GRAY='\033[0;37m'
NC='\033[0m'

clear

# 🧠 Banner ASCII (Jepang)
echo -e "${CYAN}"
cat << "EOF"
   ██▓     ██▓ ███▄    █  █    ██  ▒██   ██▒▒██   ██▒
  ▓██▒    ▓██▒ ██ ▀█   █  ██  ▓██▒ ▒▒ █ █ ▒░▒▒ █ █ ▒░
  ▒██░    ▒██▒▓██  ▀█ ██▒▓██  ▒██░ ░░  █   ░░  █   ░ 
  ▒██░    ░██░▓██▒  ▐▌██▒▓▓█  ░██░  ░ █ █ ▒  ░ █ █ ▒  
  ░██████▒░██░▒██░   ▓██░▒▒█████▓  ▒██▒ ▒██▒▒██▒ ▒██▒ 
  ░ ▒░▓  ░░▓  ░ ▒░   ▒ ▒ ░▒▓▒ ▒ ▒  ▒▒ ░ ░▓ ░▒▒ ░ ░▓ ░ 
  ░ ░ ▒  ░ ▒ ░░ ░░   ░ ▒░░░▒░ ░ ░  ░░   ░▒ ░░░   ░▒ ░ 
    ░ ░    ▒ ░   ░   ░ ░  ░░░ ░ ░   ░    ░   ░    ░   
      ░  ░ ░           ░    ░       ░    ░   ░    ░   
                                                            
              リナックス | FANNYFA DEVELOPER
EOF
# 🕹️ Info bawah banner
echo -e "${MAGENTA}────────────────────────────────────────────────────────────${NC}"
echo -e "${WHITE}リナックス ${CYAN}| ${WHITE}ファニーファ ${MAGENTA}Developer Mode${NC}"
echo -e "${MAGENTA}────────────────────────────────────────────────────────────${NC}"
echo -e "${WHITE}⚡ ${CYAN}Secure${WHITE} • ${GREEN}Fast${WHITE} • ${RED}Custom${WHITE} | Powered by ${YELLOW}FannyFa${NC}"
echo -e "${MAGENTA}────────────────────────────────────────────────────────────${NC}\n"

# 📡 Info perangkat
BRAND=$(getprop ro.product.brand || echo "Tidak Terdeteksi")
MODEL=$(getprop ro.product.model || echo "Tidak Terdeteksi")
OS_VERSION=$(getprop ro.build.version.release || echo "Tidak Terdeteksi")
DISK_USAGE=$(df -h /storage/emulated/0 | grep -v Filesystem | awk '{print $3 " / " $2 " (" $5 ")"}' || echo "Tidak Terdeteksi")

# 🔋 Status baterai via Termux API
BATTERY_DATA=$(termux-battery-status 2>/dev/null)
BATTERY_PERCENT=$(echo "$BATTERY_DATA" | grep -o '"percentage": [0-9]*' | grep -o '[0-9]*')
BATTERY_STATUS=$(echo "$BATTERY_DATA" | grep -o '"status": "[A-Z]*"' | cut -d'"' -f4)
BATTERY_TEMP=$(echo "$BATTERY_DATA" | grep -o '"temperature": [0-9]*' | grep -o '[0-9]*')

# Konversi suhu ke °C (beberapa perangkat kirim nilai ×10)
if [ -n "$BATTERY_TEMP" ]; then
    if [ "$BATTERY_TEMP" -gt 80 ]; then
        TEMP_C=$(awk "BEGIN {print $BATTERY_TEMP/10}")
    else
        TEMP_C=$BATTERY_TEMP
    fi
else
    TEMP_C="Tidak Terdeteksi"
fi

# Warna indikator baterai
if [ -z "$BATTERY_PERCENT" ]; then
  BATTERY_TEXT="${RED}Tidak Terdeteksi${NC}"
elif [ "$BATTERY_PERCENT" -ge 80 ]; then
  BATTERY_TEXT="${GREEN}${BATTERY_PERCENT}% (${BATTERY_STATUS})${NC}"
elif [ "$BATTERY_PERCENT" -ge 40 ]; then
  BATTERY_TEXT="${YELLOW}${BATTERY_PERCENT}% (${BATTERY_STATUS})${NC}"
else
  BATTERY_TEXT="${RED}${BATTERY_PERCENT}% (${BATTERY_STATUS})${NC}"
fi

# 🌐 Info jaringan (opsional, jika jq & curl tersedia)
IP_INFO=$(curl -s http://ipinfo.io)
IP_ADDRESS=$(echo "$IP_INFO" | jq -r '.ip' 2>/dev/null)
CITY=$(echo "$IP_INFO" | jq -r '.city' 2>/dev/null)
REGION=$(echo "$IP_INFO" | jq -r '.region' 2>/dev/null)
COUNTRY=$(echo "$IP_INFO" | jq -r '.country' 2>/dev/null)
LOC=$(echo "$IP_INFO" | jq -r '.loc' 2>/dev/null)

# === Tampilan Informasi Perangkat by FannyFa ===
echo -e "${CYAN}┌────────────────────────────────────────────┐${NC}"
echo -e "${BLUE}│ ${WHITE}💻  INFORMASI SISTEM & PERANGKAT           ${BLUE}│${NC}"
echo -e "${CYAN}└────────────────────────────────────────────┘${NC}"

echo -e "${MAGENTA}👤 ${WHITE}Developer    : ${YELLOW}FannyFa${NC}"
echo -e "${MAGENTA}🏷️  ${WHITE}Merek         : ${CYAN}$BRAND${NC}"
echo -e "${MAGENTA}📱 ${WHITE}Model         : ${CYAN}$MODEL${NC}"
echo -e "${MAGENTA}💿 ${WHITE}Versi OS      : ${CYAN}$OS_VERSION${NC}"
echo -e "${MAGENTA}🔋 ${WHITE}Baterai       : $BATTERY_TEXT"
echo -e "${MAGENTA}🌡️  ${WHITE}Suhu          : ${CYAN}${TEMP_C}°C${NC}"
echo -e "${MAGENTA}📂 ${WHITE}Penyimpanan   : ${CYAN}$DISK_USAGE${NC}"

if [ -n "$IP_ADDRESS" ] || [ -n "$CITY" ]; then
    echo -e "\n${CYAN}🌐 ${WHITE}Jaringan & Lokasi${NC}"
    echo -e "${MAGENTA}📡 ${WHITE}IP Address    : ${CYAN}${IP_ADDRESS:-Tidak Terdeteksi}${NC}"
    echo -e "${MAGENTA}🗺️  ${WHITE}Lokasi        : ${CYAN}${CITY:-Tidak Terdeteksi}, ${REGION:--}, ${COUNTRY:--}${NC}"
    echo -e "${MAGENTA}📍 ${WHITE}Koordinat     : ${CYAN}${LOC:-Tidak Terdeteksi}${NC}"
fi

echo -e "\n${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${YELLOW}PERINTAH : [ TOOLS ] , [ INFO ] , [ SCRIPT ]${NC}\n"